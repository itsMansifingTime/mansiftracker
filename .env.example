# Public site URL (optional; defaults to production in src/lib/site-url.ts)
# NEXT_PUBLIC_APP_URL=https://mansiftracker.vercel.app

# Supabase (server-side API routes)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hypixel API (auction craft breakdown: fetch + decode official item_bytes)
# https://developer.hypixel.net/
HYPIXEL_API_KEY=

# Craft breakdown: full Hypixel AH sync into Supabase before lookup when cooldown elapsed (when Supabase is set).
# ACTIVE_AUCTIONS_SYNC_ON_BREAKDOWN=false — disable
# ACTIVE_AUCTIONS_SYNC_MIN_INTERVAL_MS=3600000 — default 1 hour; set to 0 to sync on every breakdown request

# BIN deal scanner (GET /api/track-bin-listings): Discord when BIN is ≥ margin under craft estimate.
# Requires supabase/bin_deal_alert_sent.sql applied. With webhook + item ids, default scan is 5 pages unless overridden.
# BIN_DEAL_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional channel split:
# BIN_DEAL_KUUDRA_WEBHOOK_URL=https://discord.com/api/webhooks/...   # Kuudra armor alerts
# BIN_DEAL_HYPERION_WEBHOOK_URL=https://discord.com/api/webhooks/... # Hyperion/Necron blade alerts
# SkyBlock item ids (comma-separated). Example: Necron’s Blade line + Terminator bow:
# BIN_DEAL_ITEM_IDS=HYPERION,VALKYRIE,SCYLLA,ASTRAEA,TERMINATOR
# Kuudra armor (CRIMSON/AURORA/FERVOR/TERROR/HOLLOW tiers): dynamic ping thresholds by BIN:
#   <100M => 20M under craft, 100-200M => 30M, 200-300M => 60M, 300-500M => 100M, 500M+ => 150M.
# BIN_DEAL_KUUDRA_ARMOR_MIN_MARGIN_COINS=1  # enable Kuudra armor scan (any positive value)
# BIN_DEAL_MIN_MARGIN_COINS=1000000
# Per-item minimum margin (craft − BIN), overrides BIN_DEAL_MIN_MARGIN_COINS for that id only:
# BIN_DEAL_ITEM_MARGINS=TERMINATOR:30000000
# Necron’s Blade line default min margin is 10M under craft per tag unless overridden in BIN_DEAL_ITEM_MARGINS.
# Necron’s Blade line: above this starting bid, Discord embed is still sent but @mention is omitted (default 1.7B). Set to 0 to disable the cap (always allow mentions when mentions are enabled).
# BIN_DEAL_NECRON_BLADE_ALERT_MAX_STARTING_BID=1700000000
# (alias) BIN_DEAL_HYPERION_ALERT_MAX_STARTING_BID=1700000000
#
# Hourly TEST Discord ping (GET /api/bin-deal-test-ping): random allowlisted BIN with starting bid ≥ default 50M, full craft math, not a deal filter.
# BIN_DEAL_TEST_PING_MIN_STARTING_BID_COINS=50000000 — set 0 to disable minimum
# Requires secret: BIN_DEAL_TEST_PING_SECRET or CRON_SECRET (?secret=… or Authorization: Bearer …).
# Vercel Pro: vercel.json runs cron hourly. Hobby plan: use Railway to GET this URL once/hour instead.
# BIN_DEAL_TEST_PING_ENABLED=true
# BIN_DEAL_TEST_PING_SECRET= — optional; falls back to CRON_SECRET
# BIN_DEAL_TEST_PING_WEBHOOK_URL=https://discord.com/api/webhooks/... — required for test ping; separate channel from BIN_DEAL_ALERT_WEBHOOK_URL (no fallback)
# BIN_DEAL_TEST_PING_SEND_DISCORD=false — default off. Set true only if you want /api/bin-deal-test-ping to post to Discord.
# BIN_DEAL_USE_SUPABASE_STATE=false — default fast mode: local counters + no dedupe writes (dupes/drift possible). Set true for strict global dedupe/counters.
# BIN_DEAL_ALERT_MAX_PINGS=10 — max total Discord webhook sends across deal + test ping. Once reached, webhook messages stop entirely. Use 0 for unlimited.
# BIN_DEAL_ALERT_MENTIONS_ENABLED=false — default off. Set true to allow BIN_DEAL_ALERT_MENTION_USER_ID mentions.
# BIN_DEAL_ALERT_MENTION_USER_ID= — optional numeric Discord user id → @mention in webhook channel when a deal alert fires
# BIN_DEAL_ALERT_MENTION_MAX_PINGS=10 — max @mentions across deal + test pings (Supabase bin_deal_mention_pings + RPC). Use 0 for unlimited.
# Stop/Resume deal pings: link buttons on each alert need a public app URL (VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL / NEXT_PUBLIC_APP_URL, or set explicitly).
# BIN_DEAL_ALERTS_PUBLIC_BASE_URL=https://your-app.vercel.app
# Signing: BIN_DEAL_ALERT_PAUSE_SECRET, else CRON_SECRET / BIN_DEAL_TEST_PING_SECRET, else token from any deal webhook (main/kuudra/hyperion/wide variants).
# BIN_DEAL_ALERT_PAUSE_SECRET=
# Apply supabase/bin_deal_alert_pause.sql so pause state persists.
# BIN_DEAL_SCAN_DEFAULT_MAX_PAGES=10 — optional cap when deal alerts on and ?maxPages omitted (else full AH)
# Discord deal craft cost always uses instant sell (sell_summary); not configurable.
#
# Full AH → Supabase snapshot replace (POST /api/bin-listings/full-sync, /ah-snapshot): run supabase/truncate_bin_listings_fn.sql once so clear uses TRUNCATE (avoids DELETE timeout).
#
# Wide multi-item scan (GET /api/track-bin-listings-wide, /wide-bin-scan): 3 Hypixel pages, 60s UI interval.
# BIN_DEAL_WIDE_ITEM_IDS=VALKYRIE,TERMINATOR,...
# BIN_DEAL_WIDE_WEBHOOK_URL= — optional; defaults to BIN_DEAL_ALERT_WEBHOOK_URL
# BIN_DEAL_WIDE_KUUDRA_WEBHOOK_URL= — optional; falls back to BIN_DEAL_KUUDRA_WEBHOOK_URL, then BIN_DEAL_WIDE_WEBHOOK_URL
# BIN_DEAL_WIDE_HYPERION_WEBHOOK_URL= — optional; falls back to BIN_DEAL_HYPERION_WEBHOOK_URL, then BIN_DEAL_WIDE_WEBHOOK_URL
# BIN_DEAL_WIDE_MIN_MARGIN_COINS= — optional; defaults to BIN_DEAL_MIN_MARGIN_COINS
#
# Player seller watch (GET /api/player-auctions-watch): Discord when a watched player lists a new auction UUID (first seen this runtime).
# PLAYER_AUCTION_WATCH_WEBHOOK_URL=https://discord.com/api/webhooks/...
# PLAYER_AUCTION_WATCH_USERNAMES=Mansif — optional default if ?player / ?players omitted
# PLAYER_AUCTION_WATCH_SECRET= — optional; falls back to CRON_SECRET
#
# Mansif Hyperion sale tracker (GET /api/track-mansif-hyperion-sales): polls Hypixel auctions_ended,
# detects seller Hyperion sales, snapshots craft (instant sell), and computes profit (sold - craft).
# TRACK_MANSIF_HYPERION_SELLER=Mansif
# MANSIF_HYPERION_SALES_WEBHOOK_URL=https://discord.com/api/webhooks/...  # optional notification
# TRACK_MANSIF_HYPERION_SECRET=  # optional; falls back to CRON_SECRET
